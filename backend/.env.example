# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/casefun?schema=public"

# JWT
JWT_SECRET=your-secret-key-change-this-in-production

# Blockchain (Sepolia)
ETHEREUM_RPC_URL=
CHAIN_ID=11155111
TREASURY_ADDRESS=
TOKEN_FACTORY_ADDRESS=
TREASURY_PAYOUT_ADDRESS=
PRICE_FEED_ADDRESS=0x694AA1769357215DE4FAC081bf1f309aDC325306
TREASURY_PRIVATE_KEY=
CONFIRMATIONS=1

# BOT Chain (Bohr testnet — EVM-compatible, Chain ID 968)
# Native deposits are valued via Wrapped BOT (WBOT) price on CoinGecko.
BOT_RPC_URL=https://rpc.bohr.life
BOT_CHAIN_ID=968
BOT_TREASURY_ADDRESS=
BOT_TOKEN_FACTORY_ADDRESS=
BOT_TREASURY_PAYOUT_ADDRESS=
# Falls back to TREASURY_PRIVATE_KEY if unset.
BOT_TREASURY_PRIVATE_KEY=
BOT_CONFIRMATIONS=1

# Twitter OAuth (optional)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:5173/profile

# Telegram Mini App (optional for local website, required for /tg)
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_CLIENT_ID=
TELEGRAM_AUTH_CLIENT_SECRET=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
